# Copy to .env.local and fill in real values. Never commit .env.local.
# See README.md for where each of these comes from.

# Postgres connection string (Supabase). Session-mode pooler or direct connection.
DATABASE_URL=

# Postgres connection string via Supabase's transaction-mode pooler (port 6543). Preferred at runtime — higher concurrency under serverless.
DATABASE_URL_POOLED=

# Supabase project URL (public — used by the browser client too).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public API key (public — used by the browser client too).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth client ID (Google Cloud Console, one app grants Contacts + Gmail + Calendar).
GOOGLE_CLIENT_ID=

# Google OAuth client secret.
GOOGLE_CLIENT_SECRET=

# Google OAuth redirect URI, e.g. https://your-app.vercel.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=

# The only email allowed to sign in (single-user app).
APP_OWNER_EMAIL=

# Shared secret Vercel Cron sends as `Authorization: Bearer <value>` to /api/cron/rebuild.
CRON_SECRET=

# Optional — OpenRouter API key. Without it, LLM-backed features (summaries) degrade gracefully.
OPENROUTER_API_KEY=

# Optional — OpenRouter model id. Defaults to deepseek/deepseek-chat if unset.
# LLM for summaries. Default: google/gemini-3-flash-preview (chosen 2026-07:
# best summary quality per dollar with a solid no-training API policy).
# Any OpenRouter slug works. Fallbacks tried in order on any error.
OPENROUTER_MODEL=google/gemini-3-flash-preview

# Optional — comma-separated OpenRouter fallback model ids, tried in order if the primary fails.
OPENROUTER_FALLBACK_MODELS=

# Optional — Sentry DSN. Without it, Sentry is a complete no-op (no init, no network calls).
SENTRY_DSN=
